{
  "headers": [
    {
      "source": "/(.*\\.(css|js|webp|png|jpg|jpeg|gif|svg|woff2|woff|ttf|mp4|webm|ico))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
